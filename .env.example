# Runtime environment (copy to .env; never commit real credentials)
ENVIRONMENT=development
CONTROL_PLANE_URL=https://your-convex-site.example
WORKER_URL=https://your-worker.example
NEXT_PUBLIC_ORCHESTRATOR_URL=ws://127.0.0.1:8788/ws
APP_URL=https://your-app.example
NEXT_PUBLIC_APP_URL=https://your-app.example
HELIOS_ALLOWED_ORIGIN=https://your-app.example

# GitHub App identity (non-secret values)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
GITHUB_APP_INSTALLATION_CONFIGURED=false
GITHUB_APP_INSTALLATION_ID=
DEMO_GITHUB_INSTALLATION_ID=
DEMO_REPOSITORY=
DEMO_GITHUB_REPOSITORY_ID=
HERMES_BOT_LOGIN=

# Secrets: rotate before use and supply only in ignored .env / deployment secret stores
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY=
CONTROL_PLANE_INGEST_TOKEN=
RUNTIME_BEARER_TOKEN=
GATEWAY_BEARER_TOKEN=
PROVIDER_PROXY_TOKEN=
HERMES_GATEWAY_CLIENT_TOKEN=

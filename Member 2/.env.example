# Public service locations
CONTROL_PLANE_URL=https://your-deployment.convex.site
WORKER_URL=http://localhost:8787
NEXT_PUBLIC_ORCHESTRATOR_URL=ws://localhost:9100/ws?ticket=replace-with-short-lived-local-client-ticket
HERMES_GATEWAY_CLIENT_TOKEN=replace-with-short-lived-local-client-ticket

# Generate distinct random values of at least 32 characters. Never expose these to the browser.
CONTROL_PLANE_INGEST_TOKEN=replace-with-a-random-server-token-at-least-32-characters
RUNTIME_BEARER_TOKEN=replace-with-a-different-random-token-at-least-32-characters
GATEWAY_BEARER_TOKEN=replace-with-a-fourth-random-token-at-least-32-characters
PROVIDER_PROXY_TOKEN=replace-with-a-third-random-token-at-least-32-characters
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret

# GitHub App credentials stay in the Worker/server secret store only.
GITHUB_APP_ID=123456
GITHUB_APP_INSTALL_URL=https://github.com/apps/your-hermes-app/installations/new
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
HERMES_BOT_LOGIN=hermes-control-plane[bot]

# Optional, consent-gated provider routes. Leave unset for local-only operation.
WORKERS_AI_ENDPOINT=
WORKERS_AI_TOKEN=
HAIKU_ENDPOINT=
HAIKU_API_KEY=
LINKUP_ENDPOINT=
LINKUP_API_KEY=
ELEVENLABS_ENDPOINT=
ELEVENLABS_API_KEY=

ENVIRONMENT=development
DEMO_REPOSITORY=desync-organization/helios
DEMO_GITHUB_REPOSITORY_ID=000000000
DEMO_GITHUB_INSTALLATION_ID=000000000

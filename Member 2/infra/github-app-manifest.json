{
  "name": "Hermes Control Plane",
  "url": "https://example.invalid/hermes",
  "hook_attributes": {
    "url": "https://replace-with-worker.example/webhooks/github",
    "active": true
  },
  "redirect_url": "https://example.invalid/hermes/github/callback",
  "public": false,
  "default_permissions": {
    "actions": "read",
    "checks": "read",
    "contents": "write",
    "issues": "write",
    "metadata": "read",
    "pull_requests": "write",
    "security_events": "write",
    "workflows": "read"
  },
  "default_events": [
    "issues",
    "issue_comment",
    "pull_request",
    "pull_request_review",
    "workflow_run",
    "release",
    "repository_vulnerability_alert",
    "secret_scanning_alert",
    "code_scanning_alert"
  ]
}
